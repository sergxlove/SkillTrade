{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "content-route": {
        "ClusterId": "content-cluster",
        "Match": {
          "Path": "/api/content/{**catch-all}"
        }
      },
      "courses-route": {
        "ClusterId": "courses-cluster",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "login-route": {
        "ClusterId": "login-cluster",
        "Match": {
          "Path": "/api/login/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "content-cluster": {
        "Destinations": {
          "content-service-1": {
            "Address": "http://localhost:5281"
          }
        }
      },
      "courses-cluster": {
        "Destinations": {
          "courses-service-1": {
            "Address": "http://localhost:5282"
          }
        }
      },
      "login-cluster": {
        "Destinations": {
          "login-service-1": {
            "Address": "http://localhost:5283"
          }
        }
      }
    }
  }
}
